generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════
// 1. 用户
// ═══════════════════════════════════════════

model User {
  id                          String    @id @default(uuid())
  name                        String    @db.VarChar(100)
  email                       String?   @unique @db.VarChar(255)
  phone                       String?   @db.VarChar(20)
  password_hash               String?   @db.VarChar(255)
  avatar_url                  String?   @db.Text
  google_id                   String?   @unique @db.VarChar(100)
  region                      String    @default("US") @db.Char(2)
  willing_to_receive_for_others Boolean @default(false)
  receive_for_others_count    Int       @default(0)
  receive_for_others_rating   Decimal?  @db.Decimal(3, 2)
  default_address_id          String?
  created_at                  DateTime  @default(now())
  updated_at                  DateTime  @updatedAt

  // 关系
  addresses                   UserAddress[]
  orders                      Order[]
  wishlists                   Wishlist[]
  conversations               Conversation[]
  notifications               Notification[]
  referral_commissions_referrer  ReferralCommission[] @relation("referrer")
  referral_commissions_referred  ReferralCommission[] @relation("referred")
  transactions                Transaction[]

  @@index([region])
  @@index([email])
  @@map("users")
}

// ═══════════════════════════════════════════
// 2. 用户地址簿
// ═══════════════════════════════════════════

model UserAddress {
  id              String    @id @default(uuid())
  user_id         String
  label           String?   @db.VarChar(50)
  is_default      Boolean   @default(false)
  country_code    String    @db.Char(2)
  recipient_name  String    @db.VarChar(100)
  phone           String    @db.VarChar(20)
  postal_code     String?   @db.VarChar(20)
  admin_area1     String    @db.VarChar(100)
  admin_area2     String?   @db.VarChar(100)
  admin_area3     String?   @db.VarChar(100)
  street_address1 String    @db.VarChar(255)
  street_address2 String?   @db.VarChar(255)
  landmark        String?   @db.VarChar(255)
  lat             Decimal?  @db.Decimal(10, 7)
  lng             Decimal?  @db.Decimal(10, 7)
  formatted       String    @db.Text
  format_version  Int       @default(1)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  user            User      @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("user_addresses")
}

// ═══════════════════════════════════════════
// 3. 商品
// ═══════════════════════════════════════════

model Product {
  id                  String    @id @default(uuid())
  flylink_product_id  String    @unique @db.VarChar(100)
  flylink_url         String    @db.Text
  source_platform     String    @db.VarChar(20)
  source_url          String    @db.Text
  name                String    @db.Text
  source_price        Decimal   @db.Decimal(12, 2)
  source_currency     String    @default("CNY") @db.Char(3)
  weight_kg           Decimal?  @db.Decimal(8, 3)
  rating              Decimal?  @db.Decimal(3, 2)
  sales_count         Int?      @default(0)
  stock_status        String    @default("有货") @db.VarChar(10)
  image_url           String?   @db.Text
  sku_variants        Json?
  multi_lang_assets   Json?
  verified_status     String    @default("待核验") @db.VarChar(10)
  raw_data            Json?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  // 关系
  pricing             ProductPricing[]
  orders              Order[]
  wishlists           Wishlist[]
  recommendations     Recommendation[]

  @@index([flylink_product_id])
  @@index([source_platform, source_url])
  @@index([verified_status])
  @@map("products")
}

// ═══════════════════════════════════════════
// 4. 区域定价
// ═══════════════════════════════════════════

model ProductPricing {
  id                       String    @id @default(uuid())
  product_id               String
  region                   String    @db.Char(2)
  currency                 String    @db.Char(3)
  currency_symbol          String    @db.VarChar(5)
  local_price              Decimal   @db.Decimal(12, 2)
  shipping_rate_per_kg     Decimal   @db.Decimal(8, 2)
  shipping_category        String    @default("普通") @db.VarChar(20)
  estimated_shipping_fee   Decimal?  @db.Decimal(10, 2)
  exchange_rate_snapshot   Decimal   @db.Decimal(12, 6)
  exchange_rate_source     String    @db.VarChar(20)
  exchange_rate_updated_at DateTime?
  markup_rate              Decimal   @default(0.05) @db.Decimal(5, 4)
  status                   String    @default("生效") @db.VarChar(10)
  effective_from           DateTime  @default(now())
  effective_to             DateTime?
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt

  product                  Product   @relation(fields: [product_id], references: [id])

  @@unique([product_id, region, status])
  @@index([region, status])
  @@map("product_pricing")
}

// ═══════════════════════════════════════════
// 5. 订单
// ═══════════════════════════════════════════

model Order {
  id                            String    @id @default(uuid())
  order_no                      String    @unique @db.VarChar(20)
  user_id                       String
  flylink_order_id              String?   @db.VarChar(100)
  flylink_payment_url           String?   @db.Text
  product_id                    String
  selected_sku_id               String?   @db.VarChar(50)
  status                        String    @default("待支付") @db.VarChar(10)
  product_price                 Decimal   @db.Decimal(12, 2)
  shipping_fee                  Decimal   @db.Decimal(10, 2)
  total_amount                  Decimal   @db.Decimal(12, 2)
  currency                      String    @default("USD") @db.Char(3)
  exchange_rate                 Decimal?  @db.Decimal(12, 6)
  home_address                  Json
  delivery_batch_id             String?
  willing_to_receive_for_others Boolean   @default(false)
  receiver_discount             Decimal   @default(0) @db.Decimal(5, 4)
  shipping_discount_applied     Boolean   @default(false)
  pickup_code                   String?   @db.VarChar(10)
  created_at                    DateTime  @default(now())
  updated_at                    DateTime  @updatedAt

  user                          User              @relation(fields: [user_id], references: [id])
  product                       Product           @relation(fields: [product_id], references: [id])
  delivery_batch                DeliveryBatch?    @relation(fields: [delivery_batch_id], references: [id])
  referral_commissions          ReferralCommission[]

  @@index([user_id, created_at(sort: Desc)])
  @@index([delivery_batch_id])
  @@index([order_no])
  @@map("orders")
}

// ═══════════════════════════════════════════
// 6. 集运批次
// ═══════════════════════════════════════════

model DeliveryBatch {
  id                    String    @id @default(uuid())
  batch_no              String    @unique @db.VarChar(20)
  region                String    @db.Char(2)
  area                  String    @db.VarChar(100)
  pickup_address        Json
  pickup_contact_name   String    @db.VarChar(100)
  pickup_contact_phone  String    @db.VarChar(20)
  pickup_user_id        String?
  lat                   Decimal?  @db.Decimal(10, 7)
  lng                   Decimal?  @db.Decimal(10, 7)
  current_orders        Int       @default(0)
  current_value         Decimal   @default(0) @db.Decimal(14, 2)
  order_deadline        DateTime
  ship_date             DateTime?
  estimated_arrival     DateTime?
  status                String    @default("集货中") @db.VarChar(10)
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  orders                Order[]
  purchase_orders       PurchaseOrder[]

  @@index([region, status])
  @@map("delivery_batches")
}

// ═══════════════════════════════════════════
// 7. 心愿单
// ═══════════════════════════════════════════

model Wishlist {
  id          String    @id @default(uuid())
  user_id     String
  product_id  String
  region      String    @default("US") @db.Char(2)
  status      String    @default("待购") @db.VarChar(10)
  added_at    DateTime  @default(now())

  user        User      @relation(fields: [user_id], references: [id])
  product     Product   @relation(fields: [product_id], references: [id])

  @@unique([user_id, product_id])
  @@index([user_id, status])
  @@map("wishlists")
}

// ═══════════════════════════════════════════
// 8. 对话
// ═══════════════════════════════════════════

model Conversation {
  id                  String    @id @default(uuid())
  user_id             String
  title               String?   @db.VarChar(200)
  context_window_size Int       @default(50)
  message_count       Int       @default(0)
  is_active           Boolean   @default(true)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  user                User      @relation(fields: [user_id], references: [id])
  messages            Message[]

  @@index([user_id, updated_at(sort: Desc)])
  @@map("conversations")
}

// ═══════════════════════════════════════════
// 9. 消息（Prisma 不直接支持分区，分区在 migration SQL 中处理）
// ═══════════════════════════════════════════

model Message {
  id              String    @id @default(uuid())
  conversation_id String
  role            String    @db.VarChar(10)
  content         String    @db.Text
  card_data       Json?
  tool_calls      Json?
  feedback        Int?      @db.SmallInt
  created_at      DateTime  @default(now())

  conversation    Conversation @relation(fields: [conversation_id], references: [id])

  @@index([conversation_id, created_at])
  @@map("messages")
}

// ═══════════════════════════════════════════
// 10. 支付交易
// ═══════════════════════════════════════════

model Transaction {
  id                      String    @id @default(uuid())
  transaction_no          String    @unique @db.VarChar(30)
  order_ids               String[]
  user_id                 String
  payment_method          String    @db.VarChar(20)
  amount                  Decimal   @db.Decimal(12, 2)
  currency                String    @default("USD") @db.Char(3)
  status                  String    @default("待支付") @db.VarChar(10)
  gateway_transaction_id  String?   @db.VarChar(200)
  paid_at                 DateTime?
  refunded_at             DateTime?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  user                    User      @relation(fields: [user_id], references: [id])

  @@index([user_id, created_at(sort: Desc)])
  @@map("transactions")
}

// ═══════════════════════════════════════════
// 11. 推荐商品
// ═══════════════════════════════════════════

model Recommendation {
  id            String    @id @default(uuid())
  product_id    String
  source        String    @db.VarChar(20)
  region        String    @db.VarChar(20)
  hot_score     Int       @default(0)
  hot_label     String?   @db.VarChar(100)
  rank          Int
  period_start  DateTime  @db.Date
  period_end    DateTime  @db.Date
  metadata      Json?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  product       Product   @relation(fields: [product_id], references: [id])

  @@index([source, region, rank])
  @@index([period_start, period_end])
  @@map("recommendations")
}

// ═══════════════════════════════════════════
// 12. 通知
// ═══════════════════════════════════════════

model Notification {
  id                  String    @id @default(uuid())
  user_id             String
  type                String    @db.VarChar(20)
  title               String    @db.VarChar(200)
  content             String    @db.Text
  related_entity_type String?   @db.VarChar(20)
  related_entity_id   String?
  channel             String    @default("对话内") @db.VarChar(10)
  is_read             Boolean   @default(false)
  created_at          DateTime  @default(now())

  user                User      @relation(fields: [user_id], references: [id])

  @@index([user_id, is_read, created_at(sort: Desc)])
  @@map("notifications")
}

// ═══════════════════════════════════════════
// 13. 社区返佣
// ═══════════════════════════════════════════

model ReferralCommission {
  id                  String    @id @default(uuid())
  referrer_user_id    String
  referred_user_id    String
  referral_code       String    @db.VarChar(50)
  triggered_order_id  String?
  commission_amount   Decimal   @db.Decimal(10, 2)
  currency            String    @default("USD") @db.Char(3)
  status              String    @default("待结算") @db.VarChar(10)
  settled_at          DateTime?
  created_at          DateTime  @default(now())

  referrer            User      @relation("referrer", fields: [referrer_user_id], references: [id])
  referred            User      @relation("referred", fields: [referred_user_id], references: [id])
  triggered_order     Order?    @relation(fields: [triggered_order_id], references: [id])

  @@index([referrer_user_id, status])
  @@index([referral_code])
  @@map("referral_commissions")
}

// ═══════════════════════════════════════════
// 14. 买手
// ═══════════════════════════════════════════

model Buyer {
  id                    String    @id @default(uuid())
  name                  String    @db.VarChar(100)
  region                String    @db.VarChar(50)
  contact_phone         String    @db.VarChar(20)
  max_daily_orders      Int       @default(50)
  current_daily_orders  Int       @default(0)
  rating                Decimal?  @db.Decimal(3, 2)
  completion_rate       Decimal?  @db.Decimal(5, 4)
  status                String    @default("离线") @db.VarChar(10)
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  purchase_orders       PurchaseOrder[]

  @@map("buyers")
}

// ═══════════════════════════════════════════
// 15. 集采单
// ═══════════════════════════════════════════

model PurchaseOrder {
  id                  String    @id @default(uuid())
  batch_id            String
  buyer_id            String
  order_ids           String[]
  total_source_amount Decimal   @db.Decimal(12, 2)
  status              String    @default("待接单") @db.VarChar(10)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  batch               DeliveryBatch @relation(fields: [batch_id], references: [id])
  buyer               Buyer         @relation(fields: [buyer_id], references: [id])

  @@index([batch_id])
  @@index([buyer_id, status])
  @@index([status])
  @@map("purchase_orders")
}

// ═══════════════════════════════════════════
// 16. 国家地址格式配置
// ═══════════════════════════════════════════

model AddressFormat {
  country_code        String    @id @db.Char(2)
  country_name        String    @db.VarChar(100)
  postal_code_format  Json
  fields              Json
  display_order       Json
  admin_area1_label   String?   @db.VarChar(50)
  has_admin_area2     Boolean   @default(false)
  has_admin_area3     Boolean   @default(false)
  formatted_template  String    @db.Text

  @@map("address_formats")
}

// ═══════════════════════════════════════════
// 17. 意图配置（动态扩展）
// ═══════════════════════════════════════════

model IntentConfig {
  id            String    @id @default(uuid())
  intent_id     String    @unique @db.VarChar(50)
  patterns      Json      @default("[]")
  intent_name   String    @db.VarChar(50)
  tool_name     String?   @db.VarChar(50)
  priority      Int       @default(5)
  context_guard String?   @db.VarChar(100)
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@map("intent_configs")
}
