# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://aibuyworld:aibuyworld_dev@localhost:5432/aibuyworld

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_ACCESS_EXPIRY=30d
JWT_REFRESH_EXPIRY=365d

# Encryption key for sensitive env values (optional, for production)
# Set this to encrypt API keys and secrets in .env file
# ENCRYPTION_KEY=your-secret-passphrase

# FlyLink API (leave empty for mock data in dev)
# If ENCRYPTION_KEY is set, use encrypted values: enc:salt:iv:tag:data
FLYLINK_API_URL=https://astockd.com/fapi
FLYLINK_API_KEY=
FLYLINK_WEBHOOK_SECRET=

# LLM (leave empty for mock responses in dev)
# 使用阿里云百炼平台 Qwen 模型（兼容 OpenAI 格式）
OPENAI_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=
OPENAI_MODEL=qwen-plus
INTENT_MODEL=qwen-turbo

# CORS
CORS_ORIGIN=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
