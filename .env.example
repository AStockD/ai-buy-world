# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://aibuyworld:aibuyworld_dev@localhost:5432/aibuyworld

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# FlyLink API (leave empty for mock data in dev)
FLYLINK_API_URL=https://api.flylink.example.com
FLYLINK_API_KEY=
FLYLINK_WEBHOOK_SECRET=

# LLM (leave empty for mock responses in dev)
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# CORS
CORS_ORIGIN=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
